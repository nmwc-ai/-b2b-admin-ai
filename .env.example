# ── Supabase Postgres (서버리스: 반드시 transaction pooler :6543 사용) ──
# 예: postgresql://postgres.<ref>:<pw>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# ── Claude API ──
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# ── Gmail (IMAP 수신/초안) ──
GMAIL_ADDRESS=
GMAIL_APP_PASSWORD=
B2B_LABEL=B2B_INQUIRY

# ── 어드민 Basic Auth (/sign·/cron 제외 전 경로) ──
ADMIN_USER=antiegg
ADMIN_PASSWORD=

# ── Vercel Cron 보호 ──
CRON_SECRET=

# ── 공개 주소 (서명/다운로드 링크용) ──
APP_BASE_URL=

# ── 디렉터 / 회사 정보 (settings 테이블 폴백) ──
DIRECTOR_NAME=
DIRECTOR_EMAIL=
ANTIEGG_CEO=
ANTIEGG_BIZ_NO=
ANTIEGG_PHONE=
ANTIEGG_EMAIL=
ANTIEGG_ADDR=

# ── Notion 임포트 (scripts/notion_import.py 전용) ──
NOTION_TOKEN=
NOTION_DB_ID=
